{
  "name": "@skyphusion-labs/vivijure-core",
  "version": "0.9.1",
  "description": "Shared Vivijure orchestration: module registry, film pipeline, platform ICD. Consumed by vivijure (CF) and vivijure-local (Node).",
  "license": "AGPL-3.0-only",
  "type": "module",
  "homepage": "https://github.com/skyphusion-labs/vivijure-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/skyphusion-labs/vivijure-core.git"
  },
  "keywords": [
    "vivijure",
    "ai-video",
    "orchestration",
    "agpl"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "import": "./dist/platform/index.js"
    },
    "./platform/*": {
      "types": "./dist/platform/*.d.ts",
      "import": "./dist/platform/*.js"
    },
    "./modules/*": {
      "types": "./dist/modules/*.d.ts",
      "import": "./dist/modules/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true --coverage.provider=v8 --coverage.reporter=cobertura --coverage.reporter=text",
    "parity:vivijure": "bash scripts/parity-with-vivijure.sh",
    "parity:vivijure:strict": "bash scripts/parity-with-vivijure.sh --strict",
    "sync:module-types": "cp ../vivijure/src/modules/types.ts src/modules/types.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
